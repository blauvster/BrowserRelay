# ──────────────────────────────────────────────
# BrowserRelay – example environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────

# Admin secret used to protect token-management endpoints.
# Choose a long, random string (e.g. `openssl rand -hex 32`).
ADMIN_SECRET=change-me-to-a-very-long-random-string

# Path to the TinyDB JSON file used to persist API tokens.
# Relative paths are resolved from the project root.
TOKEN_DB_PATH=data/tokens.json

# Session idle timeout in seconds before auto-cleanup.
SESSION_TIMEOUT_SECONDS=3600

# Host/port for the Uvicorn server.
HOST=0.0.0.0
PORT=8000

# Log level: debug | info | warning | error
LOG_LEVEL=info

# Set to 1 to run Playwright in headed (visible) mode — useful for local debugging.
PLAYWRIGHT_HEADED=0
